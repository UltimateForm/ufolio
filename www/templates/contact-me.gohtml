{{ define "contact-me" }}
<div
    class="window"
    id="contact-me-window"
    style="top: 10%; left: 30%"
    aria-hidden="true"
    tabindex="-1"
>
    <div class="title-bar">
        <div class="title-bar-text">contact me</div>
        {{ template "window-controls" }}
    </div>
    <div class="window-body">
        <p>this is a personal portfolio in development</p>
        <p>maybe come back later :D</p>
    </div>
</div>
{{ end }}
